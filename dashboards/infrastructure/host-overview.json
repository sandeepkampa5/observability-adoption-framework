{
  "$schema": "https://raw.githubusercontent.com/observability-adoption-framework/schemas/v1/dashboard.schema.json",
  "metadata": {
    "name": "Infrastructure - Service-Aware Host & Container Monitoring",
    "description": "Infrastructure monitoring with service-aware context, implementing the phased maturity-driven approach. Key to achieving 85% faster detection and 90% war room reduction.",
    "version": "1.0.0",
    "framework_phase": "Phase 1 - Foundation",
    "author": "Sandeep Kampa",
    "attribution": "Architecture from 'Adoption of Infrastructure Monitoring at Splunk' (July 2024) - 10,571+ community views",
    "tags": ["infrastructure", "hosts", "containers", "cpu", "memory", "disk", "network"],
    "compatible_backends": ["splunk", "datadog", "grafana", "newrelic", "elastic", "prometheus"]
  },
  "variables": [
    { "name": "environment", "label": "Environment", "type": "custom", "values": ["production", "staging", "development"] },
    { "name": "host", "label": "Host", "type": "query", "query": "label_values(system_cpu_utilization, host_name)" },
    { "name": "service", "label": "Service (Context)", "type": "query", "query": "label_values(system_cpu_utilization{host_name='${host}'}, service_name)" }
  ],
  "rows": [
    {
      "title": "Fleet Overview",
      "height": 3,
      "panels": [
        { "title": "Total Hosts", "type": "stat", "metric": { "name": "system.cpu.utilization", "aggregation": "count_distinct", "group_by": ["host.name"] } },
        { "title": "Hosts Critical", "type": "stat", "metric": { "name": "system.cpu.utilization", "aggregation": "count_distinct", "group_by": ["host.name"], "filters": { "value": "> 0.9" } }, "thresholds": { "good": 0, "warning": 1, "critical": 3 } },
        { "title": "Avg CPU (Fleet)", "type": "gauge", "metric": { "name": "system.cpu.utilization", "aggregation": "avg", "unit": "percent" }, "thresholds": { "good": 70, "warning": 85, "critical": 95 } },
        { "title": "Avg Memory (Fleet)", "type": "gauge", "metric": { "name": "system.memory.utilization", "aggregation": "avg", "unit": "percent" }, "thresholds": { "good": 75, "warning": 85, "critical": 95 } }
      ]
    },
    {
      "title": "CPU & Memory (Host Detail)",
      "height": 5,
      "panels": [
        { "title": "CPU Utilization Over Time", "type": "timeseries", "metric": { "name": "system.cpu.utilization", "aggregation": "avg", "group_by": ["cpu.state"], "unit": "percent", "filters": { "host.name": "${host}" } }, "visualization": { "stacking": "normal" } },
        { "title": "Memory Usage Over Time", "type": "timeseries", "metric": { "name": "system.memory.usage", "aggregation": "avg", "group_by": ["memory.state"], "unit": "bytes", "filters": { "host.name": "${host}" } }, "visualization": { "stacking": "normal" } }
      ]
    },
    {
      "title": "Disk & Network",
      "height": 4,
      "panels": [
        { "title": "Disk I/O", "type": "timeseries", "metric": { "name": "system.disk.io", "aggregation": "rate", "group_by": ["disk.direction"], "unit": "bytes/s", "filters": { "host.name": "${host}" } } },
        { "title": "Filesystem Usage", "type": "table", "metric": { "name": "system.filesystem.utilization", "group_by": ["mountpoint"], "aggregation": "last", "unit": "percent" }, "thresholds": { "good": 70, "warning": 85, "critical": 95 } },
        { "title": "Network Throughput", "type": "timeseries", "metric": { "name": "system.network.io", "aggregation": "rate", "group_by": ["network.direction"], "unit": "bytes/s" } }
      ]
    },
    {
      "title": "Container Metrics (Service-Aware)",
      "height": 5,
      "description": "Correlate infrastructure health with the services running on this host",
      "panels": [
        { "title": "Container CPU by Service", "type": "timeseries", "metric": { "name": "container.cpu.utilization", "aggregation": "avg", "group_by": ["service.name"], "unit": "percent" } },
        { "title": "Container Memory by Service", "type": "timeseries", "metric": { "name": "container.memory.usage", "aggregation": "avg", "group_by": ["service.name"], "unit": "bytes" } },
        { "title": "Container Restarts", "type": "stat", "metric": { "name": "k8s.container.restarts", "aggregation": "sum", "group_by": ["service.name"] }, "thresholds": { "good": 0, "warning": 3, "critical": 10 } }
      ]
    }
  ],
  "alerts": [
    { "name": "CPU Critical", "condition": "system.cpu.utilization > 95% for 5m", "severity": "critical" },
    { "name": "Memory Critical", "condition": "system.memory.utilization > 95% for 3m", "severity": "critical" },
    { "name": "Disk Space Critical", "condition": "system.filesystem.utilization > 90%", "severity": "critical" },
    { "name": "Container Crash Loop", "condition": "rate(k8s.container.restarts) > 3 in 10m", "severity": "warning" }
  ]
}
